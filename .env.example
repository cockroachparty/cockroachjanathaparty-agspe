# AGSPE Environment Variables
# Repository: https://github.com/cockroachparty/cockroachjanathaparty-agspe
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://agspe:agspe123@localhost:5432/agspe

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=change-me-in-production-use-strong-random-key

# News API Keys (comma-separated for multiple providers)
NEWS_API_KEYS=

# Proxy Rotator URL (optional, for web scraping)
PROXY_ROTATOR_URL=

# CORS Origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Application Settings
APP_NAME=AGSPE - Adani Group Strategic Prediction Engine
APP_VERSION=1.0.0
DEBUG=true

# Rate Limiting
CRAWL_DELAY_SECONDS=2.0
MAX_REQUESTS_PER_MINUTE=30

# Currency Conversion
INR_TO_USD_RATE=83.5

# Validation Thresholds
VALIDATION_HIGH_THRESHOLD=0.7
VALIDATION_MEDIUM_THRESHOLD=0.4

# Cross-Verification Window (hours)
CROSS_VERIFICATION_WINDOW_HOURS=24
